#!/usr/bin/env bash
# =============================================================================
# init.lmstudio — LM Studio CLI Management Wrapper
# All commands validated against official LM Studio docs (v0.0.47)
# Docs: https://lmstudio.ai/docs/cli
# =============================================================================
# Usage: init.lmstudio <command> [options]
#
# Commands:
#   daemon  up|down|status|update   Manage the LMS daemon (llmster)
#   ls | list                       List all local models on disk
#   ps                              List models loaded in memory
#   load    <model-key> [flags]     Load a model into memory
#   unload  <model-key|--all>       Unload a model from memory
#   import  <path> [flags]          Import a local .gguf file into LM Studio
#   download <model-id>             Download a model from LM Studio Hub
#   server  start|stop|status       Manage the local inference server
#   help                            Show this help message
# =============================================================================

set -euo pipefail

# ── Colour palette ────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Helpers ───────────────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}[OK]${RESET}    $*"; }
warn()    { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
error()   { echo -e "${RED}[ERROR]${RESET} $*" >&2; }
die()     { error "$*"; exit 1; }

separator() {
    echo -e "${CYAN}$(printf '─%.0s' {1..60})${RESET}"
}

require_lms() {
    if ! command -v lms &>/dev/null; then
        die "'lms' not found in PATH. Is LM Studio installed?"
    fi
}

# LD_LIBRARY_PATH must be cleared on Linux for daemon up (llmster conflict)
lms_clean() {
    env -u LD_LIBRARY_PATH lms "$@"
}

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
    echo -e ""
    echo -e "${BOLD}init.lmstudio${RESET} — LM Studio CLI Management Wrapper"
    echo -e "Validated against: lms v0.0.47  |  Docs: https://lmstudio.ai/docs/cli"
    echo -e ""
    echo -e "${BOLD}USAGE${RESET}"
    echo -e "  init.lmstudio <command> [subcommand|options]"
    echo -e ""
    echo -e "${BOLD}DAEMON${RESET}  (manages the headless llmster process)"
    echo -e "  daemon up               Start llmster  [env -u LD_LIBRARY_PATH lms daemon up]"
    echo -e "  daemon down             Stop llmster   [lms daemon down]"
    echo -e "  daemon status           Show status    [lms daemon status]"
    echo -e "  daemon update           Update binary  [lms daemon update]"
    echo -e "  restart                 down → up in sequence"
    echo -e ""
    echo -e "${BOLD}MODELS${RESET}"
    echo -e "  ls | list               List all models on disk            [lms ls]"
    echo -e "  ps                      List models loaded in memory       [lms ps]"
    echo -e "  load  <model-key>       Load a model                       [lms load]"
    echo -e "    --gpu max|off|0.0-1.0   GPU offload fraction"
    echo -e "    --context-length <N>    Context window size"
    echo -e "    --ttl <seconds>         Auto-unload after N idle seconds"
    echo -e "    --identifier <name>     Assign a custom API identifier"
    echo -e "    --estimate-only         Preview VRAM usage without loading"
    echo -e "  unload <model-key>      Unload a specific model            [lms unload]"
    echo -e "  unload --all            Unload all loaded models           [lms unload --all]"
    echo -e "  import <path>           Import a local .gguf into LM Studio [lms import]"
    echo -e "    --copy                  Copy file instead of moving it"
    echo -e "    --hard-link             Hard-link instead of moving"
    echo -e "    --symbolic-link         Symbolic-link instead of moving"
    echo -e "    --user-repo <u/r>       Set target namespace (skips prompts)"
    echo -e "    -y                      Skip confirmations"
    echo -e "    --dry-run               Preview what would happen"
    echo -e "  download <model-id>     Download a model from LM Studio Hub [lms get]"
    echo -e ""
    echo -e "${BOLD}SERVER${RESET}  (local inference API server)"
    echo -e "  server start            Start server (skips if already running) [lms server start]"
    echo -e "  server stop             Stop the inference server               [lms server stop]"
    echo -e "  server status           Show server status                      [lms server status]"
    echo -e ""
    echo -e "${BOLD}OTHER${RESET}"
    echo -e "  help                    Show this help message"
    echo -e ""
    echo -e "${BOLD}EXAMPLES${RESET}"
    echo -e "  init.lmstudio daemon up"
    echo -e "  init.lmstudio daemon status"
    echo -e "  init.lmstudio ls"
    echo -e "  init.lmstudio ps"
    echo -e "  init.lmstudio load                    ← interactive menu"
    echo -e "  init.lmstudio unload                  ← interactive menu"
    echo -e "  init.lmstudio unload --all"
    echo -e "  init.lmstudio import                  ← interactive prompts"
    echo -e "  init.lmstudio server status"
    echo -e "  init.lmstudio server start"
    echo -e "  init.lmstudio server stop"
    echo -e ""
}

# ── Daemon ────────────────────────────────────────────────────────────────────
cmd_daemon() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        up)
            info "Starting llmster daemon (LD_LIBRARY_PATH cleared)…"
            # 'lms daemon up' is the correct verb — NOT 'lms daemon start'
            lms_clean daemon up "$@" \
                && success "Daemon started." \
                || die "Failed to start daemon."
            separator
            cmd_daemon status
            ;;
        down)
            info "Stopping llmster daemon…"
            # 'lms daemon down' is the correct verb — NOT 'lms daemon stop'
            lms daemon down "$@" \
                && success "Daemon stopped." \
                || die "Failed to stop daemon."
            ;;
        status)
            info "LMS daemon status:"
            separator
            lms daemon status "$@" || true
            separator
            ;;
        update)
            info "Updating LMS daemon…"
            lms daemon update "$@" \
                && success "Daemon updated successfully." \
                || die "Daemon update failed."
            ;;
        "")
            error "Missing subcommand. Use: up | down | status | update"
            usage; exit 1
            ;;
        *)
            die "Unknown daemon subcommand: '$subcmd'. Use: up | down | status | update"
            ;;
    esac
}

# ── List all local models on disk: lms ls ─────────────────────────────────────
cmd_ls() {
    info "Models available on disk:"
    separator
    lms ls "$@" \
        || die "lms ls failed. Is the daemon running?  →  init.lmstudio daemon status"
    separator
}

# ── List loaded models in memory: lms ps ─────────────────────────────────────
cmd_ps() {
    info "Models currently loaded in memory:"
    separator
    lms ps "$@" \
        || die "lms ps failed. Is the daemon running?  →  init.lmstudio daemon status"
    separator
}

# ── Interactive numbered-menu picker ─────────────────────────────────────────
# Usage: pick_from_list <prompt> <item1> <item2> ...
# Sets global PICK_RESULT to the chosen item, or returns 1 if cancelled.
pick_from_list() {
    local prompt="$1"; shift
    local items=("$@")
    local count=${#items[@]}

    if [[ $count -eq 0 ]]; then
        error "No items available to select from."
        return 1
    fi

    local cancel_num=$(( count + 1 ))
    echo ""
    local i=1
    for item in "${items[@]}"; do
        printf "  ${CYAN}%2d)${RESET} %s\n" "$i" "$item"
        (( i++ ))
    done
    printf "  ${RED}%2d)${RESET} Cancel\n" "$cancel_num"
    echo ""

    local choice
    while true; do
        read -rp "$(echo -e "${BOLD}${prompt}${RESET} [1-${cancel_num}]: ")" choice
        if [[ "$choice" =~ ^[0-9]+$ ]]; then
            if (( choice == cancel_num )); then
                info "Cancelled."
                return 1
            elif (( choice >= 1 && choice <= count )); then
                PICK_RESULT="${items[$((choice-1))]}"
                return 0
            fi
        fi
        warn "Enter a number between 1 and ${cancel_num}."
    done
}

# ── LM Studio REST API ────────────────────────────────────────────────────────
LMS_API_PORT="${LMS_API_PORT:-9000}"
LMS_API_BASE="http://localhost:${LMS_API_PORT}/api/v0"

# Query /api/v0/models; filter by state ("loaded"|"not-loaded") or "" for all.
# Prints one model id per line.  Returns 1 if the API is unreachable.
get_api_models() {
    local state_filter="${1:-}"
    local response
    response=$(curl -sf --max-time 3 "${LMS_API_BASE}/models" 2>/dev/null) || return 1
    jq -r --arg s "$state_filter" '
        .data[]
        | select(.type == "llm")
        | select($s == "" or .state == $s)
        | .id
    ' <<<"$response" 2>/dev/null | sort -u
}

# ── Parse model keys from LM Studio API (fallback: lms ls) ───────────────────
get_local_model_keys() {
    local keys
    keys=$(get_api_models "") && [[ -n "$keys" ]] && { echo "$keys"; return; }
    # Fallback: lms ls prints lines like  publisher/model-name/file.gguf  (size)
    lms ls 2>/dev/null \
        | awk 'NF >= 1 { print $1 }' \
        | grep '/' \
        | sort -u
}

# ── Parse loaded model keys from LM Studio API (fallback: lms ps) ────────────
get_loaded_model_keys() {
    local keys
    keys=$(get_api_models "loaded") && [[ -n "$keys" ]] && { echo "$keys"; return; }
    # Fallback: lms ps prints "Identifier: publisher/model-key" lines
    lms ps 2>/dev/null \
        | grep -i 'identifier:' \
        | awk '{print $NF}' \
        | sort -u
}

# ── Load a model: lms load ────────────────────────────────────────────────────
# No args → interactive menu from live lms ls output + flag prompts.
# With args → non-interactive passthrough (original behaviour preserved).
cmd_load() {
    local model_key="${1:-}"

    if [[ -z "$model_key" ]]; then
        # ── Interactive mode ──────────────────────────────────────────────────
        info "Fetching available models from lms ls…"
        mapfile -t model_list < <(get_local_model_keys)

        if [[ ${#model_list[@]} -eq 0 ]]; then
            die "No local models found. Run 'init.lmstudio download <model-id>' first."
        fi

        separator
        pick_from_list "Select model to load" "${model_list[@]}" || return 0
        model_key="$PICK_RESULT"

        # ── GPU offload ───────────────────────────────────────────────────────
        echo ""
        info "GPU offload  (Enter to skip)"
        echo -e "  ${CYAN}1)${RESET} max   — offload all layers to GPU"
        echo -e "  ${CYAN}2)${RESET} off   — CPU only"
        echo -e "  ${CYAN}3)${RESET} 0–1   — fractional (e.g. 0.75)"
        echo -e "  ${CYAN}4)${RESET} skip  — let LM Studio decide"
        echo ""
        local gpu_flag=""
        read -rp "$(echo -e "${BOLD}GPU option${RESET} [1-4, default 4]: ")" gpu_choice
        case "${gpu_choice:-4}" in
            1) gpu_flag="--gpu max" ;;
            2) gpu_flag="--gpu off" ;;
            3)
                read -rp "$(echo -e "${BOLD}Fraction${RESET} (0.0–1.0): ")" frac
                gpu_flag="--gpu ${frac}"
                ;;
            4) gpu_flag="" ;;
            *) warn "Unrecognised choice, skipping GPU flag." ;;
        esac

        # ── Context length ────────────────────────────────────────────────────
        echo ""
        local ctx_flag=""
        read -rp "$(echo -e "${BOLD}Context length${RESET} (tokens, Enter to skip): ")" ctx
        [[ -n "$ctx" ]] && ctx_flag="--context-length ${ctx}"

        # ── TTL ───────────────────────────────────────────────────────────────
        echo ""
        local ttl_flag=""
        read -rp "$(echo -e "${BOLD}Auto-unload TTL${RESET} (idle seconds, Enter to skip): ")" ttl
        [[ -n "$ttl" ]] && ttl_flag="--ttl ${ttl}"

        # ── Identifier ────────────────────────────────────────────────────────
        echo ""
        local id_flag=""
        read -rp "$(echo -e "${BOLD}Custom API identifier${RESET} (Enter to skip): ")" ident
        [[ -n "$ident" ]] && id_flag="--identifier ${ident}"

        # ── Estimate only ─────────────────────────────────────────────────────
        echo ""
        local est_flag=""
        read -rp "$(echo -e "${BOLD}Estimate VRAM only, don't load?${RESET} [y/N]: ")" est
        [[ "${est,,}" == "y" ]] && est_flag="--estimate-only"

        # ── Build and run ─────────────────────────────────────────────────────
        # shellcheck disable=SC2086
        local cmd_args=("$model_key")
        for flag in $gpu_flag $ctx_flag $ttl_flag $id_flag $est_flag; do
            cmd_args+=("$flag")
        done

        separator
        info "Running: lms load ${cmd_args[*]}"
        separator
        lms load "${cmd_args[@]}" \
            && success "Model loaded: $model_key" \
            || die "Failed to load model: $model_key"

    else
        # ── Non-interactive passthrough ───────────────────────────────────────
        shift
        info "Loading model: ${BOLD}${model_key}${RESET}"
        lms load "$model_key" "$@" \
            && success "Model loaded: $model_key" \
            || die "Failed to load model: $model_key"
    fi
}

# ── Unload a model: lms unload ────────────────────────────────────────────────
# No args → interactive menu from live lms ps output.
# --all   → unload everything immediately.
# <key>   → non-interactive passthrough.
cmd_unload() {
    local target="${1:-}"

    if [[ -z "$target" ]]; then
        # ── Interactive mode ──────────────────────────────────────────────────
        info "Fetching loaded models from lms ps…"
        mapfile -t loaded_list < <(get_loaded_model_keys)

        if [[ ${#loaded_list[@]} -eq 0 ]]; then
            warn "No models are currently loaded in memory."
            return 0
        fi

        # Prepend an "Unload ALL" option
        local menu_items=("── Unload ALL models ──" "${loaded_list[@]}")

        separator
        pick_from_list "Select model to unload" "${menu_items[@]}" || return 0
        local chosen="$PICK_RESULT"

        if [[ "$chosen" == "── Unload ALL models ──" ]]; then
            echo ""
            read -rp "$(echo -e "${YELLOW}Unload ALL models? [y/N]:${RESET} ")" confirm
            [[ "${confirm,,}" != "y" ]] && { info "Aborted."; return 0; }
            info "Unloading all loaded models…"
            lms unload --all \
                && success "All models unloaded." \
                || die "Failed to unload all models."
        else
            separator
            info "Unloading model: ${BOLD}${chosen}${RESET}"
            lms unload "$chosen" \
                && success "Model unloaded: $chosen" \
                || die "Failed to unload model: $chosen"
        fi

    elif [[ "$target" == "--all" ]]; then
        info "Unloading all loaded models…"
        lms unload --all \
            && success "All models unloaded." \
            || die "Failed to unload all models."
    else
        # ── Non-interactive passthrough ───────────────────────────────────────
        info "Unloading model: ${BOLD}${target}${RESET}"
        lms unload "$target" \
            && success "Model unloaded: $target" \
            || die "Failed to unload model: $target"
    fi
}

# ── Import a local model file: lms import ─────────────────────────────────────
# NOTE: 'lms link' is a different feature (LM Link for remote devices).
#       The correct command to bring a local .gguf into LM Studio is 'lms import'.
# No args → interactive prompts for path + each flag.
# With args → non-interactive passthrough.
cmd_import() {
    local model_path="${1:-}"

    if [[ -z "$model_path" ]]; then
        # ── Interactive mode ──────────────────────────────────────────────────
        echo ""
        info "Import a local model file into LM Studio  (lms import)"
        separator

        # ── File path ─────────────────────────────────────────────────────────
        while true; do
            read -rp "$(echo -e "${BOLD}Path to .gguf file${RESET}: ")" model_path
            model_path="${model_path/#\~/$HOME}"   # expand ~ manually
            [[ -f "$model_path" ]] && break
            warn "File not found: $model_path — try again."
        done

        # ── File handling mode ────────────────────────────────────────────────
        echo ""
        info "How should LM Studio handle the file?"
        echo -e "  ${CYAN}1)${RESET} move          — move file into LM Studio models dir (default)"
        echo -e "  ${CYAN}2)${RESET} --copy         — copy, keep original"
        echo -e "  ${CYAN}3)${RESET} --hard-link    — hard-link, keep original"
        echo -e "  ${CYAN}4)${RESET} --symbolic-link — symlink, keep original"
        echo ""
        local file_flag=""
        read -rp "$(echo -e "${BOLD}File handling${RESET} [1-4, default 1]: ")" fh
        case "${fh:-1}" in
            1) file_flag="" ;;
            2) file_flag="--copy" ;;
            3) file_flag="--hard-link" ;;
            4) file_flag="--symbolic-link" ;;
            *) warn "Unrecognised, defaulting to move." ;;
        esac

        # ── User/repo namespace ───────────────────────────────────────────────
        echo ""
        local repo_flag=""
        read -rp "$(echo -e "${BOLD}Target namespace${RESET} (user/repo, Enter to be prompted by lms): ")" repo
        [[ -n "$repo" ]] && repo_flag="--user-repo ${repo}"

        # ── Skip confirmations ────────────────────────────────────────────────
        echo ""
        local yes_flag=""
        read -rp "$(echo -e "${BOLD}Skip lms confirmations?${RESET} [y/N]: ")" skip_confirm
        [[ "${skip_confirm,,}" == "y" ]] && yes_flag="-y"

        # ── Dry run ───────────────────────────────────────────────────────────
        echo ""
        local dry_flag=""
        read -rp "$(echo -e "${BOLD}Dry run only (preview, no changes)?${RESET} [y/N]: ")" dry
        [[ "${dry,,}" == "y" ]] && dry_flag="--dry-run"

        # ── Build and run ─────────────────────────────────────────────────────
        local cmd_args=("$model_path")
        for flag in $file_flag $repo_flag $yes_flag $dry_flag; do
            cmd_args+=("$flag")
        done

        separator
        info "Running: lms import ${cmd_args[*]}"
        separator
        lms import "${cmd_args[@]}" \
            && success "Model imported: $model_path" \
            || die "Failed to import model: $model_path"

    else
        # ── Non-interactive passthrough ───────────────────────────────────────
        [[ ! -e "$model_path" ]] && die "File not found: $model_path"
        shift
        info "Importing local model: ${BOLD}${model_path}${RESET}"
        lms import "$model_path" "$@" \
            && success "Model imported: $model_path" \
            || die "Failed to import model: $model_path"
    fi
}

# ── Download a model: lms get ─────────────────────────────────────────────────
cmd_download() {
    local model_id="${1:-}"
    [[ -z "$model_id" ]] && die \
        "Usage: init.lmstudio download <model-id>
       Example: init.lmstudio download bartowski/gemma-2-9b-it-GGUF"

    shift  # pass through optional flags like --gguf, --mlx, quantization spec
    info "Downloading model: ${BOLD}${model_id}${RESET}"
    warn "This may take a while depending on model size and connection speed."
    separator
    lms get "$model_id" "$@" \
        && success "Download complete: $model_id" \
        || die "Failed to download model: $model_id"
}

# ── Server: check if already running ─────────────────────────────────────────
# Returns 0 if running, 1 if not. Parses lms server status output.
server_is_running() {
    lms server status 2>/dev/null | grep -qi "running"
}

# ── Server sub-commands ───────────────────────────────────────────────────────
cmd_server() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        start)
            info "Checking server status…"
            if server_is_running; then
                success "Server is already running — nothing to do."
                separator
                lms server status || true
                separator
            else
                info "Server is not running. Starting…"
                lms server start "$@" \
                    && success "Server started." \
                    || die "Failed to start server."
                separator
                lms server status || true
                separator
            fi
            ;;
        stop)
            info "Stopping LM Studio inference server…"
            lms server stop "$@" \
                && success "Server stopped." \
                || die "Failed to stop server."
            ;;
        status)
            info "LM Studio server status:"
            separator
            lms server status "$@" || true
            separator
            ;;
        "")
            error "Missing subcommand. Use: start | stop | status"
            usage; exit 1
            ;;
        *)
            die "Unknown server subcommand: '$subcmd'. Use: start | stop | status"
            ;;
    esac
}

# ── Restart convenience wrapper ───────────────────────────────────────────────
cmd_restart() {
    info "Restarting LMS daemon…"
    cmd_daemon down || true
    sleep 2
    cmd_daemon up
}

# ── Main dispatcher ───────────────────────────────────────────────────────────
main() {
    require_lms

    local command="${1:-help}"
    shift || true

    case "$command" in
        daemon)          cmd_daemon   "$@" ;;
        ls|list)         cmd_ls       "$@" ;;
        ps)              cmd_ps       "$@" ;;
        load)            cmd_load     "$@" ;;
        unload)          cmd_unload   "$@" ;;
        import)          cmd_import   "$@" ;;
        download|get)    cmd_download "$@" ;;
        server)          cmd_server   "$@" ;;
        restart)         cmd_restart  "$@" ;;
        help|--help|-h)  usage ;;
        *)
            error "Unknown command: '$command'"
            usage; exit 1
            ;;
    esac
}

main "$@"

